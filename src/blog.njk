
<style>
    /* Resource Center Core Styles */
    :root {
        --charcoal: #232B2B;
        --sage-dark: #4A5D4E;
        --sage: #7A9A82;
        --sage-light: #EBF0EC;
        --sand-light: #F9F8F6;
        --white: #FFFFFF;
        --text-main: #2D312E;
        --text-muted: #5A605B;
        --font-serif: 'Playfair Display', Georgia, serif;
        --font-sans: 'Inter', sans-serif;
    }

    body {
        font-family: var(--font-sans);
        color: var(--text-main);
        background-color: var(--white);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
    }

    .container {
        width: 100%;
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 2rem;
    }

    .section-padding {
        padding: 5rem 0;
    }

    .bg-sand { background-color: var(--sand-light); }
    .bg-white { background-color: var(--white); }
    .bg-charcoal { background-color: var(--charcoal); }
    .bg-sage-light { background-color: var(--sage-light); }

    .section-header {
        text-align: center;
        margin-bottom: 3.5rem;
    }

    .section-header h2 {
        font-family: var(--font-serif);
        font-size: 2.5rem;
        color: var(--charcoal);
        font-weight: 400;
        margin-bottom: 0.5rem;
    }

    .section-header p {
        color: var(--text-muted);
        font-size: 1.1rem;
        max-width: 700px;
        margin: 0 auto;
    }

    /* Primary CTA Button Component */
    .btn-primary {
        display: inline-block;
        background-color: var(--charcoal);
        color: var(--white);
        text-decoration: none;
        padding: 0.85rem 1.75rem;
        border-radius: 4px;
        font-weight: 600;
        font-size: 1rem;
        transition: all 0.2s ease;
        border: none;
        cursor: pointer;
    }

    .btn-primary:hover {
        background-color: var(--sage-dark);
        transform: translateY(-1px);
    }

    /* Meta tags (Tags + Read Time) */
    .post-meta {
        display: flex;
        align-items: center;
        gap: 1rem;
        font-size: 0.85rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 0.75rem;
    }

    .meta-tag {
        color: var(--sage-dark);
        background-color: var(--sage-light);
        padding: 0.2rem 0.6rem;
        border-radius: 3px;
    }

    .meta-read {
        color: var(--text-muted);
    }
